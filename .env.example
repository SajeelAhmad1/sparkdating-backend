# Redis (required for BullMQ job queue + FCM worker)
# Use REDIS_URL for hosted Redis (e.g. Upstash, Redis Cloud)
REDIS_URL=redis://localhost:6379
# Or set individual fields:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Prisma MongoDB connection string (required)
DATABASE_URL="mongodb+srv://<user>:<password>@<host>/<db>?retryWrites=true&w=majority"

JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# If you later want to send real SMS, plug a provider here (Twilio, etc).
SMS_PROVIDER=mock

# Email OTP (SMTP)
EMAIL_PROVIDER=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Google Sign-In (ID token verification)
GOOGLE_CLIENT_ID=change_me_google_client_id
GOOGLE_CLIENT_SECRET=change_me_google_client_secret

# Firebase Admin / FCM (optional). Prefer a file path (same idea as Firebase docs require("./key.json")).
# Path is relative to project root unless absolute. Example if the file is in the repo root:
# FIREBASE_SERVICE_ACCOUNT_PATH=./spark-dating-9efc8-firebase-adminsdk-fbsvc-553fe17a96.json
FIREBASE_SERVICE_ACCOUNT_PATH=

# Or paste the whole service account JSON as a single line (e.g. in cloud hosting without a file).
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Or standard Google env: absolute path to the JSON file
# GOOGLE_APPLICATION_CREDENTIALS=E:/path/to/serviceAccount.json
