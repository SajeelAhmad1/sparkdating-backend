generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  phone        String?
  email        String?
  passwordHash String?
  googleSub    String?

  interests UserInterest[]
  profile   Profile?
  location  UserLocation?
  swipesSent     Swipe[] @relation("swipes_sent")
  swipesReceived Swipe[] @relation("swipes_received")
  matchesAsUser1 Match[] @relation("match_user1")
  matchesAsUser2 Match[] @relation("match_user2")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  userId    String @unique @db.ObjectId
  user      User   @relation(fields: [userId], references: [id])

  firstName String
  lastName  String
  gender    String
  dob       DateTime
  bio       String?
  height    Int?
  ethnicity String?
  photos    String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Interest {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  name     String @unique
  category String

  users UserInterest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserInterest {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  userId     String @db.ObjectId
  interestId String @db.ObjectId

  user     User     @relation(fields: [userId], references: [id])
  interest Interest @relation(fields: [interestId], references: [id])

  @@unique([userId, interestId])
  @@index([userId])
  @@index([interestId])
}

model SignupSession {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  phone         String?
  email         String?
  otpHash       String
  otpExpiresAt  DateTime
  otpVerifiedAt DateTime?
  usedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([email])
  @@index([otpExpiresAt])
  @@index([usedAt])
}

model RefreshToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model OauthSignupSession {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  provider    String
  providerSub String
  email       String?
  displayName String?
  givenName   String?
  familyName  String?
  picture     String?
  expiresAt   DateTime
  usedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provider, providerSub])
  @@index([expiresAt])
}

model UserLocation {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  // GeoJSON Point: { type: "Point", coordinates: [lng, lat] }
  point Json
  lat   Float
  lng   Float

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Swipe {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  fromUserId String @db.ObjectId
  toUserId   String @db.ObjectId
  action     SwipeAction

  fromUser User @relation("swipes_sent", fields: [fromUserId], references: [id])
  toUser   User @relation("swipes_received", fields: [toUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([toUserId, action])
}

model Match {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  user1Id String @db.ObjectId
  user2Id String @db.ObjectId

  user1 User @relation("match_user1", fields: [user1Id], references: [id])
  user2 User @relation("match_user2", fields: [user2Id], references: [id])

  matchedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

model ServiceArea {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String  @unique
  countryCode String
  isActive    Boolean @default(true)

  // GeoJSON Polygon or MultiPolygon
  geometry Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([countryCode])
}

enum SwipeAction {
  like
  swipe
}

model DiscoveryFilter {
  id                 String  @id @default(auto()) @map("_id") @db.ObjectId
  key                String  @unique
  youngerAgeDelta    Int     @default(5)
  olderAgeDelta      Int     @default(5)
  maxDistanceKm      Int     @default(50)
  isActive           Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

