generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  phone     String   @unique
  email     String?
  googleSub String?
  firstName String
  lastName  String
  gender    String
  dob       DateTime
  bio       String?
  height    Int?
  ethnicity String?
  photos    String[] @default([])

  interests UserInterest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Interest {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  name     String @unique
  category String

  users UserInterest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserInterest {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  userId     String @db.ObjectId
  interestId String @db.ObjectId

  user     User     @relation(fields: [userId], references: [id])
  interest Interest @relation(fields: [interestId], references: [id])

  @@unique([userId, interestId])
  @@index([userId])
  @@index([interestId])
}

model SignupSession {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  phone         String
  otpHash       String
  otpExpiresAt  DateTime
  otpVerifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
}

model RefreshToken {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @db.ObjectId
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model OauthSignupSession {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  provider    String
  providerSub String
  email       String?
  displayName String?
  givenName   String?
  familyName  String?
  picture     String?
  expiresAt   DateTime
  usedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provider, providerSub])
  @@index([expiresAt])
}
